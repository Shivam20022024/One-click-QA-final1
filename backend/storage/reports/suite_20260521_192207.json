{
  "application": "SauceDemo",
  "application_map": {
    "pages": [
      "Login Page",
      "Account Page",
      "Checkout Page"
    ],
    "features": [
      "User Authentication",
      "Account Management",
      "Checkout Process"
    ],
    "flows": [
      "Login Flow",
      "Account Details Flow",
      "Checkout Flow"
    ]
  },
  "test_suite": {
    "tests": [
      {
        "feature": "User Authentication",
        "test_type": "positive",
        "test_name": "Successful Login",
        "expected_intent": "success",
        "steps": [
          {
            "action": "goto",
            "url": "https://www.saucedemo.com/",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "value": "standard_user",
            "selector": "#user-name",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "value": "secret_sauce",
            "selector": "#password",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": "#inventory_container",
            "expected_intent": "success"
          }
        ]
      },
      {
        "feature": "User Authentication",
        "test_type": "negative",
        "test_name": "Unsuccessful Login with Invalid Credentials",
        "expected_intent": "error",
        "steps": [
          {
            "action": "goto",
            "url": "https://www.saucedemo.com/",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "value": "invalid_user",
            "selector": "#user-name",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "value": "wrong_password",
            "selector": "#password",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".error-message-container",
            "expected_intent": "error"
          }
        ]
      },
      {
        "feature": "User Authentication",
        "test_type": "edge",
        "test_name": "Login with Empty Credentials",
        "expected_intent": "validation",
        "steps": [
          {
            "action": "goto",
            "url": "https://www.saucedemo.com/",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".error-message-container",
            "expected_intent": "validation"
          }
        ]
