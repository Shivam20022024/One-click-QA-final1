  "test_suite": {
    "tests": [
      {
        "feature": "User Login",
        "test_type": "positive",
        "test_name": "Successful Login",
        "expected_intent": "success",
        "steps": [
          {
            "action": "goto",
            "url": "https://www.saucedemo.com",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#user-name",
            "value": "standard_user",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "secret_sauce",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".inventory_list",
            "expected_intent": "success"
          }
        ]
      },
      {
        "feature": "User Login",
        "test_type": "negative",
        "test_name": "Unsuccessful Login with Invalid Credentials",
        "expected_intent": "error",
        "steps": [
          {
            "action": "goto",
            "url": "https://www.saucedemo.com",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#user-name",
            "value": "invalid_user",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "wrong_password",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".error-message-container",
            "expected_intent": "error"
          }
        ]
      },
