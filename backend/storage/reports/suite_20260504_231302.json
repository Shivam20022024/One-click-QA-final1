{
  "application": "Sauce Demo",
  "application_map": {
    "pages": [
      "Login Page",
      "Inventory Page",
      "Cart Page",
      "Checkout Page",
      "Checkout Complete Page"
    ],
    "features": [
      "User Login",
      "Product Browsing",
      "Add to Cart",
      "Checkout Process"
    ],
    "flows": [
      "Login to Inventory",
      "Add Product to Cart",
      "Checkout Flow"
    ]
