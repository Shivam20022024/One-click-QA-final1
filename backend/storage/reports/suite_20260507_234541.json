{
  "application": "Sauce Demo",
  "application_map": {
    "pages": [
      "Login Page",
      "Product Page",
      "Cart Page",
      "Checkout Page",
      "Order Confirmation Page",
      "Home Page"
    ],
    "features": [
      "Login",
      "Add to Cart",
      "Checkout",
      "Fill Details",
      "Place Order",
      "Home Navigation"
