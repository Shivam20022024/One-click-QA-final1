{
  "application": "SauceDemo",
  "application_map": {
    "pages": [
      "Login Page",
      "Product Page",
      "Cart Page"
    ],
    "features": [
      "User Authentication",
      "Product Browsing",
      "Shopping Cart Management"
    ],
    "flows": [
      "User Login Flow",
      "Product Purchase Flow"
    ]
  },
  "test_suite": {
    "tests": [
      {
        "feature": "User Authentication",
        "test_type": "positive",
        "test_name": "Successful Login",
        "expected_intent": "success",
        "steps": [
          {
            "action": "fill",
            "selector": "#user-name",
            "value": "standard_user",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "secret_sauce",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".product_label",
            "expected_intent": "success"
          }
        ]
      },
      {
        "feature": "User Authentication",
        "test_type": "negative",
        "test_name": "Unsuccessful Login with Invalid Credentials",
        "expected_intent": "error",
        "steps": [
          {
            "action": "fill",
            "selector": "#user-name",
            "value": "invalid_user",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "wrong_password",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".error-message-container",
            "expected_intent": "error"
          }
        ]
      },
      {
        "feature": "User Authentication",
        "test_type": "edge",
        "test_name": "Login with Empty Credentials",
        "expected_intent": "validation",
        "steps": [
          {
            "action": "fill",
            "selector": "#user-name",
            "value": "",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".error-message-container",
            "expected_intent": "validation"
          }
        ]
      },
      {
        "feature": "User Authentication",
        "test_type": "e2e",
        "test_name": "Login and Navigate to Product Page",
        "expected_intent": "success",
        "steps": [
          {
            "action": "fill",
            "selector": "#user-name",
            "value": "standard_user",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "secret_sauce",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".product_label",
            "expected_intent": "success"
          }
        ]
      },
      {
        "feature": "Product Browsing",
        "test_type": "positive",
        "test_name": "View Product Details",
        "expected_intent": "success",
        "steps": [
          {
            "action": "fill",
            "selector": "#user-name",
            "value": "standard_user",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "secret_sauce",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": ".inventory_item:first-child",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".inventory_details_desc",
            "expected_intent": "success"
          }
        ]
      },
      {
        "feature": "Product Browsing",
        "test_type": "negative",
        "test_name": "Attempt to View Non-Existent Product",
        "expected_intent": "error",
        "steps": [
          {
            "action": "fill",
            "selector": "#user-name",
            "value": "standard_user",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "secret_sauce",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": ".inventory_item:nth-child(100)",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".error-message-container",
            "expected_intent": "error"
          }
        ]
      },
      {
        "feature": "Shopping Cart Management",
        "test_type": "positive",
        "test_name": "Add Product to Cart",
        "expected_intent": "success",
        "steps": [
          {
            "action": "fill",
            "selector": "#user-name",
            "value": "standard_user",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "secret_sauce",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": ".btn_inventory",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".shopping_cart_badge",
            "expected_intent": "success"
          }
        ]
      },
      {
        "feature": "Shopping Cart Management",
        "test_type": "negative",
        "test_name": "Attempt to Add Product When Not Logged In",
        "expected_intent": "error",
        "steps": [
          {
            "action": "click",
            "selector": ".btn_inventory",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".error-message-container",
            "expected_intent": "error"
          }
        ]
      },
      {
        "feature": "Shopping Cart Management",
        "test_type": "edge",
        "test_name": "Add Same Product to Cart Multiple Times",
        "expected_intent": "validation",
        "steps": [
          {
            "action": "fill",
            "selector": "#user-name",
            "value": "standard_user",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "secret_sauce",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": ".btn_inventory",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": ".btn_inventory",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".shopping_cart_badge",
            "expected_intent": "validation"
          }
        ]
      },
      {
        "feature": "Shopping Cart Management",
        "test_type": "e2e",
        "test_name": "Complete Purchase Flow",
        "expected_intent": "success",
        "steps": [
          {
            "action": "fill",
            "selector": "#user-name",
            "value": "standard_user",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "secret_sauce",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": ".btn_inventory",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": ".shopping_cart_link",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#checkout",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#first-name",
            "value": "John",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#last-name",
            "value": "Doe",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#postal-code",
            "value": "12345",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".complete-header",
            "expected_intent": "success"
          }
        ]
      }
    ]
  }
}