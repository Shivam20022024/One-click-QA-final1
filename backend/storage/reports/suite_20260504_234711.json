{
  "application": "Sauce Demo",
  "application_map": {
    "pages": [
      "login",
      "inventory",
      "cart",
      "checkout",
      "checkout_complete"
    ],
    "features": [
      "user_login",
      "product_listing",
      "add_to_cart",
      "checkout_process"
    ],
    "flows": [
      "login_to_inventory",
      "add_product_to_cart",
      "checkout_flow"
