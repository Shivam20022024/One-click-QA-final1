  "test_suite": {
    "tests": [
      {
        "feature": "Login",
        "test_type": "positive",
        "test_name": "Successful Login",
        "expected_intent": "success",
        "steps": [
          {
            "action": "goto",
            "url": "https://www.saucedemo.com/",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "value": "standard_user",
            "selector": "#user-name",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "value": "secret_sauce",
            "selector": "#password",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".product_list",
            "expected_intent": "success"
          }
        ]
      },
      {
        "feature": "Login",
        "test_type": "negative",
        "test_name": "Unsuccessful Login with Invalid Credentials",
