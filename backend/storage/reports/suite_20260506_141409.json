{
  "application": "OrangeHRM",
  "application_map": {
    "pages": [
      "Login",
      "Dashboard",
      "Employee List",
      "Add Employee",
      "View Employee"
    ],
    "features": [
      "User Authentication",
      "Employee Management"
    ],
    "flows": [
      "Login Flow",
      "Employee Management Flow"
    ]
  },
  "test_suite": {
    "tests": [
      {
        "feature": "User Authentication",
        "test_type": "positive",
        "test_name": "Successful Login",
        "expected_intent": "success",
        "steps": [
          {
            "action": "goto",
            "url": "https://opensource-demo.orangehrmlive.com/",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "value": "Admin",
            "selector": "#txtUsername",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "value": "admin123",
            "selector": "#txtPassword",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#btnLogin",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": "#welcome",
            "expected_intent": "success"
          }
        ]
      },
      {
        "feature": "User Authentication",
        "test_type": "negative",
        "test_name": "Unsuccessful Login with Invalid Credentials",
        "expected_intent": "error",
        "steps": [
          {
            "action": "goto",
            "url": "https://opensource-demo.orangehrmlive.com/",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "value": "InvalidUser",
            "selector": "#txtUsername",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "value": "InvalidPass",
            "selector": "#txtPassword",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#btnLogin",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": "#spanMessage",
            "expected_intent": "error"
          }
        ]
      },
      {
        "feature": "User Authentication",
        "test_type": "edge",
