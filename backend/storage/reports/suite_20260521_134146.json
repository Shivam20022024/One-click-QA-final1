  "test_suite": {
    "tests": [
      {
        "feature": "Login",
        "test_type": "positive",
        "test_name": "Successful login",
        "expected_intent": "success",
        "steps": [
          {
            "action": "goto",
            "url": "https://www.saucedemo.com",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#user-name",
            "value": "standard_user",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "secret_sauce",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".inventory_item",
            "expected_intent": "success"
          }
        ]
      },
      {
        "feature": "Login",
        "test_type": "negative",
        "test_name": "Invalid credentials show error",
