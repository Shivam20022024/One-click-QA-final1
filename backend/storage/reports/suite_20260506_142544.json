{
  "application": "Web Application",
  "application_map": {
    "pages": [
      "login",
      "dashboard",
      "catalog",
      "cart",
      "checkout"
    ],
    "features": [
      "login",
      "logout",
      "product listing",
      "add to cart",
      "remove from cart",
      "cart validation",
      "checkout"
    ],
    "flows": [
      "login to dashboard",
      "browse products and manage cart",
      "checkout flow"
    ]
