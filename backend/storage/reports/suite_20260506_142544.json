  "test_suite": {
    "tests": [
      {
        "feature": "login",
        "test_type": "positive",
        "test_name": "Successful login",
        "expected_intent": "success",
        "steps": [
          {
            "action": "goto",
            "url": "https://opensource-demo.orangehrmlive.com",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#username",
            "value": "valid_user",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "selector": "#password",
            "value": "valid_password",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#login-button",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": ".dashboard",
            "expected_intent": "success"
          }
        ]
      },
      {
        "feature": "login",
        "test_type": "negative",
        "test_name": "Invalid credentials show error",
