  "test_suite": {
    "tests": [
      {
        "feature": "User Authentication",
        "test_type": "positive",
        "test_name": "Successful Login",
        "expected_intent": "success",
        "steps": [
          {
            "action": "goto",
            "url": "https://opensource-demo.orangehrmlive.com/",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "value": "Admin",
            "selector": "#txtUsername",
            "expected_intent": "success"
          },
          {
            "action": "fill",
            "value": "admin123",
            "selector": "#txtPassword",
            "expected_intent": "success"
          },
          {
            "action": "click",
            "selector": "#btnLogin",
            "expected_intent": "success"
          },
          {
            "action": "assert_visible",
            "selector": "#welcome",
            "expected_intent": "success"
          }
        ]
      },
      {
        "feature": "User Authentication",
        "test_type": "negative",
        "test_name": "Unsuccessful Login with Invalid Credentials",
